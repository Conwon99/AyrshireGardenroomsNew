---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Header } from "@/sections/Header";
import { Footer } from "@/sections/Footer";
---

<BaseLayout
  title="Page Not Found | Ayrshire Garden Rooms"
  description="Sorry, we couldn't find that page. Explore our garden room services across Ayrshire or get in touch for a free quote."
  canonical="https://ayrshiregardenrooms.co.uk/404"
  noindex={true}
>
  <div class="text-neutral-600 text-lg not-italic normal-nums font-medium accent-auto bg-[#323232] box-border caret-transparent block tracking-[normal] leading-[27px] list-outside list-disc min-h-full pointer-events-auto text-start indent-[0px] normal-case visible border-separate font-manrope">
    <Header client:load />
    <section class="pt-[140px] pb-[100px] md:pt-[180px] md:pb-[140px] px-4 sm:px-5 md:px-8">
      <div class="max-w-[700px] mx-auto text-center text-white">
        <h1 class="text-5xl sm:text-6xl md:text-7xl font-bold mb-6">404</h1>
        <p class="text-xl md:text-2xl font-semibold mb-4">Page Not Found</p>
        <p class="text-base md:text-lg text-white/80 mb-10 leading-relaxed">
          Sorry, we couldn't find the page you were looking for. It may have moved or no longer exists.
          Here are some helpful links instead:
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/"
            class="inline-block bg-green-800 hover:bg-green-900 text-white font-semibold py-3 px-6 rounded-lg transition-colors duration-300"
          >
            Home
          </a>
          <a
            href="/garden-rooms"
            class="inline-block bg-[#787e59] hover:bg-[#8a9168] text-white font-semibold py-3 px-6 rounded-lg transition-colors duration-300"
          >
            Garden Rooms
          </a>
          <a
            href="/locations"
            class="inline-block bg-[#787e59] hover:bg-[#8a9168] text-white font-semibold py-3 px-6 rounded-lg transition-colors duration-300"
          >
            Areas We Serve
          </a>
          <a
            href="/contact"
            class="inline-block border border-white/40 hover:border-white text-white font-semibold py-3 px-6 rounded-lg transition-colors duration-300"
          >
            Contact Us
          </a>
        </div>
      </div>
    </section>
    <Footer client:load />
  </div>
</BaseLayout>
