---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Header } from "@/sections/Header";
import { Footer } from "@/sections/Footer";
import { HomeHero } from "@/pages/index/sections/HomeHero";
import { GardenRoomsFeatures } from "@/pages/garden-rooms/sections/Features";
import { GardenRoomsGallery } from "@/pages/garden-rooms/sections/Gallery";
import { GardenRoomsTestimonials } from "@/pages/garden-rooms/sections/Testimonials";
import { GardenRoomsFAQ } from "@/pages/garden-rooms/sections/FAQ";
import { GardenRoomsContactForm } from "@/pages/garden-rooms/sections/ContactForm";
import { ServicesSection } from "@/sections/ServicesSection";
---

<BaseLayout 
  title="Ayrshire Garden Rooms | Garden Room Installation Across Ayrshire"
  description="Professional garden room installation across Ayrshire - Irvine, Kilmarnock, Ayr, Troon, Prestwick and more. Transform your outdoor space with a custom garden room. Free quotes, fully insured."
  canonical="https://ayrshiregardenrooms.co.uk/"
  keywords="garden rooms ayrshire, garden room installation ayrshire, garden rooms irvine, garden rooms kilmarnock, garden rooms ayr, custom garden rooms ayrshire, garden office ayrshire, garden room builders ayrshire"
>
    <div class="text-neutral-600 text-lg not-italic normal-nums font-medium accent-auto bg-[#323232] box-border caret-transparent block tracking-[normal] leading-[27px] list-outside list-disc min-h-full pointer-events-auto text-start indent-[0px] normal-case visible border-separate font-manrope">
      <Header client:load />
      <div class="pt-[80px] md:pt-[100px]">
        <HomeHero client:load />
      </div>
      <GardenRoomsFeatures client:load />
      <ServicesSection client:load />
      <GardenRoomsGallery client:load />
      <GardenRoomsTestimonials client:load />
      <GardenRoomsFAQ client:load />
      <GardenRoomsContactForm client:load />
      <Footer client:load />
    </div>
</BaseLayout>
