---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Header } from "@/sections/Header";
import { Footer } from "@/sections/Footer";
import { LocationsHero } from "@/pages/locations/sections/LocationsHero";
import { LocationsGrid } from "@/pages/locations/sections/LocationsGrid";
import { centralBeltLocations, ayrshireLocations } from "@/data/locations";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Locations", url: "/locations" },
];
---

<BaseLayout
  title="Areas We Serve | Garden Rooms Across Ayrshire | Ayrshire Garden Rooms"
  description="Garden room installation across 40 towns in and around Ayrshire, plus the Scotland Central Belt. We serve Irvine, Kilmarnock, Ayr, Troon, Largs and more. Free quotes."
  canonical="https://ayrshiregardenrooms.co.uk/locations"
  keywords="garden rooms ayrshire, garden room installation irvine, garden rooms kilmarnock, garden rooms ayr, garden rooms troon, garden room builders ayrshire"
  breadcrumbs={breadcrumbs}
>
  <div class="text-neutral-600 text-lg not-italic normal-nums font-medium accent-auto bg-[#323232] box-border caret-transparent block tracking-[normal] leading-[27px] list-outside list-disc min-h-full pointer-events-auto text-start indent-[0px] normal-case visible border-separate font-manrope">
    <Header client:load />
    <div class="pt-[80px] md:pt-[100px]">
      <LocationsHero client:load />
      <LocationsGrid
        client:load
        regionTitle="Ayrshire"
        regionSubtitle="Our home turf — 40 towns across North, East, and South Ayrshire."
        locations={ayrshireLocations}
      />
      <LocationsGrid
        client:load
        regionTitle="Also Serving the Scotland Central Belt"
        locations={centralBeltLocations}
      />
    </div>
    <Footer client:load />
  </div>
</BaseLayout>
